# Spring Configuration
SPRING_PROFILES_ACTIVE=docker
SERVER_PORT=8080

# MySQL Database Configurations
DB_ROOT_PASSWORD=root
DB_DATABASE=sentinel_db
DB_USER=sentinel_user
