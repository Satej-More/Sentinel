DB_PORT=3306

# Redis Configurations
REDIS_PORT=6379

# JWT Token Security Configurations
# Note: JWT_SECRET MUST be a base64-encoded string that represents at least 256 bits of key strength.
# Default base64 represents: "super-secure-key-that-is-at-least-256-bits-long-for-hmac-sha256"
JWT_SECRET=c3VwZXItc2VjdXJlLWtleS10aGF0LWlzLWF0LWxlYXN0LTI1Ni1iaXRzLWxvbmctZm9yLWhtYWMtc2hhMjU2
JWT_EXPIRATION_MS=3600000
JWT_REFRESH_EXPIRATION_MS=86400000
